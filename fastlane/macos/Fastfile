require_relative "../patches/developer_id_application_certificate_type_patch"

def shell_escape(value)
  Shellwords.escape(value)
end

def workspace_root
  File.expand_path("../..", __dir__)
end

MACOS_RELEASE_FLAVOR_CONFIGS = {
  "mainnet" => {
    app_name: "Vizor",
    artifact_name: "Vizor",
    bundle_id: "com.keplr.vizor",
    bundle_id_name: "Vizor",
    app_icon_file: "AppIcon",
    sparkle_feed_asset_name: "appcast.xml",
    sparkle_public_key_env: "SPARKLE_PUBLIC_ED_KEY_MAINNET",
    sparkle_private_key_env: "SPARKLE_PRIVATE_ED_KEY_MAINNET",
    zcash_default_network: "main",
    volume_name: "Install Vizor Wallet"
  },
  "testnet" => {
    app_name: "Vizor Testnet",
    artifact_name: "Vizor-Testnet",
    bundle_id: "com.keplr.vizor.testnet",
    bundle_id_name: "Vizor Testnet",
    app_icon_file: "TestnetAppIcon",
    sparkle_feed_asset_name: "appcast-testnet.xml",
    sparkle_public_key_env: "SPARKLE_PUBLIC_ED_KEY_TESTNET",
    sparkle_private_key_env: "SPARKLE_PRIVATE_ED_KEY_TESTNET",
    zcash_default_network: "test",
    volume_name: "Install Vizor Testnet Wallet"
  }
}.freeze

DEFAULT_MACOS_RELEASE_FLAVORS = ["mainnet", "testnet"].freeze
DEVELOPER_ID_APPLICATION_IDENTITY = "Developer ID Application: Chainapsis Inc. (SZTB68DXM4)".freeze

def normalize_macos_release_flavor(flavor)
  normalized = flavor.to_s.strip.downcase
  return normalized if MACOS_RELEASE_FLAVOR_CONFIGS.key?(normalized)

  UI.user_error!("Unsupported macOS release flavor: #{flavor}. Expected one of: #{MACOS_RELEASE_FLAVOR_CONFIGS.keys.join(", ")}")
end

def macos_release_flavors
  raw = ENV["VIZOR_MACOS_FLAVORS"].to_s.strip
  if raw.empty?
    single_flavor = ENV["VIZOR_MACOS_FLAVOR"].to_s.strip
    return [normalize_macos_release_flavor(single_flavor)] unless single_flavor.empty?

    return DEFAULT_MACOS_RELEASE_FLAVORS
  end

  flavors = raw.split(",").map(&:strip).reject(&:empty?)
  UI.user_error!("VIZOR_MACOS_FLAVORS must include at least one flavor") if flavors.empty?
  flavors.map { |flavor| normalize_macos_release_flavor(flavor) }.uniq
end

def single_macos_release_flavor(options = {})
  raw = options[:flavor] || ENV["VIZOR_MACOS_FLAVOR"]
  raw = raw.to_s.strip
  raw.empty? ? "mainnet" : normalize_macos_release_flavor(raw)
end

def release_tag_info(tag)
  match = /\Arelease\/v(?<base_version>\d+\.\d+\.\d+)(?<prerelease_suffix>-rc\.\d+)?\z/.match(tag.to_s)
  UI.user_error!("Unsupported release tag format: #{tag}") unless match

  prerelease_suffix = match[:prerelease_suffix].to_s
  {
    base_version: match[:base_version],
    asset_version: "#{match[:base_version]}#{prerelease_suffix}",
    is_prerelease: !prerelease_suffix.empty?
  }
end

def release_build_number
  build_number = ENV["RELEASE_BUILD_NUMBER"].to_s.strip
  UI.user_error!("RELEASE_BUILD_NUMBER must be a positive integer") unless build_number.match?(/\A[1-9]\d*\z/)
  build_number
end

def release_metadata(flavor: "mainnet")
  flavor = normalize_macos_release_flavor(flavor)
  flavor_config = MACOS_RELEASE_FLAVOR_CONFIGS.fetch(flavor)
  tag = ENV["RELEASE_TAG"]

  if tag.to_s.empty?
    ref_type = ENV.fetch("GITHUB_REF_TYPE")
    UI.user_error!("RELEASE_TAG is required when GITHUB_REF_TYPE is not 'tag'") unless ref_type == "tag"
    tag = ENV.fetch("GITHUB_REF_NAME")
  end

  tag_info = release_tag_info(tag)
  version = tag_info.fetch(:base_version)
  asset_version = tag_info.fetch(:asset_version)
  build_number = release_build_number

  unless ENV["GITHUB_RELEASE_PRERELEASE"].to_s.strip.empty?
    env_prerelease = release_boolean_env("GITHUB_RELEASE_PRERELEASE")
    UI.user_error!("GITHUB_RELEASE_PRERELEASE=#{env_prerelease} does not match release tag #{tag}") unless env_prerelease == tag_info.fetch(:is_prerelease)
  end

  app_name = flavor_config.fetch(:app_name)
  artifact_name = flavor_config.fetch(:artifact_name)
  dist_dir = File.join(workspace_root, "dist", "macos")
  sparkle_dir = File.join(dist_dir, "sparkle", flavor)
  app_path = File.join(workspace_root, "build", "macos", "Build", "Products", "Release", "#{app_name}.app")

  {
    flavor: flavor,
    app_name: app_name,
    artifact_name: artifact_name,
    bundle_id: flavor_config.fetch(:bundle_id),
    bundle_id_name: flavor_config.fetch(:bundle_id_name),
    app_icon_file: flavor_config.fetch(:app_icon_file),
    zcash_default_network: flavor_config.fetch(:zcash_default_network),
    volume_name: flavor_config.fetch(:volume_name),
    version: version,
    asset_version: asset_version,
    is_prerelease: tag_info.fetch(:is_prerelease),
    build_number: build_number,
    tag: tag,
    release_name: ENV["RELEASE_NAME"] || tag,
    dist_dir: dist_dir,
    sparkle_dir: sparkle_dir,
    app_path: app_path,
    zip_path: File.join(dist_dir, "#{artifact_name}-#{asset_version}-macos.zip"),
    dmg_path: File.join(dist_dir, "#{artifact_name}-#{asset_version}-macos.dmg"),
    appcast_path: File.join(sparkle_dir, flavor_config.fetch(:sparkle_feed_asset_name)),
    sparkle_feed_url: "https://github.com/#{ENV.fetch("RELEASE_REPOSITORY")}/releases/latest/download/#{flavor_config.fetch(:sparkle_feed_asset_name)}",
    sparkle_release_notes_path: File.join(sparkle_dir, "#{artifact_name}-#{asset_version}-macos.md"),
    sparkle_public_key_env: flavor_config.fetch(:sparkle_public_key_env),
    sparkle_private_key_env: flavor_config.fetch(:sparkle_private_key_env)
  }
end

def release_boolean_env(key)
  ENV[key].to_s.downcase == "true"
end

def match_readonly?
  release_boolean_env("MATCH_READONLY")
end

def match_git_branch
  branch = ENV["MATCH_GIT_BRANCH"].to_s.strip
  branch.empty? ? "main" : branch
end

def signing_keychain_name
  keychain_name = ENV.fetch("MACOS_KEYCHAIN_NAME", "").strip
  keychain_name = "fastlane-signing.keychain-db" if keychain_name.empty?
  keychain_name
end

def signing_keychain_path
  File.expand_path(File.join("~/Library/Keychains", signing_keychain_name))
end

def match_certificate_password
  ENV.fetch("MATCH_CERTIFICATE_PASSWORD")
end

def sparkle_enabled_for_release?(_metadata)
  false
end

def sparkle_public_ed_key(metadata)
  env_key = metadata.fetch(:sparkle_public_key_env)
  public_key = ENV[env_key].to_s.strip
  UI.user_error!("#{env_key} is required for #{metadata[:flavor]} release builds") if public_key.empty?
  public_key
end

def sparkle_private_ed_key(metadata)
  ENV.fetch(metadata.fetch(:sparkle_private_key_env))
end

def github_release_page_url(metadata)
  "https://github.com/#{ENV.fetch("RELEASE_REPOSITORY")}/releases/tag/#{metadata[:tag]}"
end

def github_release_download_base_url(metadata)
  "https://github.com/#{ENV.fetch("RELEASE_REPOSITORY")}/releases/download/#{metadata[:tag]}/"
end

def with_restored_file(path)
  original_contents = File.binread(path)
  yield(path)
ensure
  File.binwrite(path, original_contents) if defined?(original_contents) && original_contents
end

def configure_sparkle_info_plist!(plist_path, metadata)
  sh("/usr/bin/plutil -replace SUPublicEDKey -string #{shell_escape(sparkle_public_ed_key(metadata))} #{shell_escape(plist_path)}")
  sh("/usr/bin/plutil -replace SUFeedURL -string #{shell_escape(metadata.fetch(:sparkle_feed_url))} #{shell_escape(plist_path)}")
end

def sparkle_tool_path(tool_name)
  candidates = Dir.glob(File.expand_path("~/Library/Developer/Xcode/DerivedData/*/SourcePackages/artifacts/sparkle/Sparkle/bin/#{tool_name}"))
  tool_path = candidates.max_by { |path| File.mtime(path) }
  UI.user_error!("Could not locate Sparkle tool #{tool_name}. Resolve Swift package dependencies first.") unless tool_path
  tool_path
end

def http_get(uri, headers: {}, limit: 5)
  UI.user_error!("Too many redirects fetching #{uri}") if limit <= 0

  request = Net::HTTP::Get.new(uri)
  headers.each { |key, value| request[key] = value }

  response = Net::HTTP.start(uri.host, uri.port, use_ssl: uri.scheme == "https") do |http|
    http.request(request)
  end

  case response
  when Net::HTTPSuccess
    response.body
  when Net::HTTPRedirection
    http_get(URI(response["location"]), headers: headers, limit: limit - 1)
  else
    UI.user_error!("HTTP GET failed for #{uri}: #{response.code} #{response.message}")
  end
end

def github_api_json(url)
  JSON.parse(
    http_get(
      URI(url),
      headers: {
        "Authorization" => "Bearer #{ENV.fetch("GITHUB_TOKEN")}",
        "Accept" => "application/vnd.github+json",
        "User-Agent" => "vizor-fastlane",
        "X-GitHub-Api-Version" => "2022-11-28"
      }
    )
  )
end

def previous_release_zip_assets(metadata, limit: 5)
  releases = github_api_json("https://api.github.com/repos/#{ENV.fetch("RELEASE_REPOSITORY")}/releases?per_page=100")
  zip_asset_pattern = /\A#{Regexp.escape(metadata.fetch(:artifact_name))}-\d+\.\d+\.\d+-macos\.zip\z/

  releases.filter_map do |release|
    tag_name = release["tag_name"].to_s
    next if release["draft"] || release["prerelease"] || tag_name == metadata[:tag]
    next unless tag_name.match?(/\Arelease\/v\d+\.\d+\.\d+\z/)

    asset = Array(release["assets"]).find { |candidate| candidate["name"].to_s.match?(zip_asset_pattern) }
    next unless asset

    {
      tag: tag_name,
      name: asset.fetch("name"),
      download_url: asset.fetch("browser_download_url")
    }
  end.first(limit)
end

def download_previous_release_archives!(archives_dir, metadata)
  previous_release_zip_assets(metadata).each do |asset|
    destination_path = File.join(archives_dir, asset.fetch(:name))
    next if File.exist?(destination_path)

    UI.message("Downloading prior Sparkle archive #{asset.fetch(:name)} from #{asset.fetch(:tag)}")
    File.binwrite(
      destination_path,
      http_get(
        URI(asset.fetch(:download_url)),
        headers: {
          "User-Agent" => "vizor-fastlane"
        }
      )
    )
  end
end

def write_sparkle_release_notes!(notes_path, metadata)
  File.write(
    notes_path,
    <<~MARKDOWN
      # #{metadata[:release_name]}

      See the full release notes on GitHub:

      [#{metadata[:tag]}](#{github_release_page_url(metadata)})
    MARKDOWN
  )
end

def validate_sparkle_environment!(metadata)
  return unless sparkle_enabled_for_release?(metadata)

  sparkle_public_ed_key(metadata)

  private_key_env = metadata.fetch(:sparkle_private_key_env)
  UI.user_error!("#{private_key_env} is required for stable #{metadata[:flavor]} Sparkle releases") if ENV[private_key_env].to_s.strip.empty?
end

def codesign_for_distribution!(path, preserve_metadata: nil)
  UI.user_error!("Expected codesign input at #{path}") unless File.exist?(path)

  command = [
    "/usr/bin/codesign",
    "--force",
    "--sign", DEVELOPER_ID_APPLICATION_IDENTITY,
    "--timestamp",
    "--options", "runtime"
  ]
  command << "--preserve-metadata=#{preserve_metadata}" if preserve_metadata
  command << path

  sh(command.map { |part| shell_escape(part) }.join(" "))
end

def resign_sparkle_for_notarization!(metadata)
  app_path = metadata.fetch(:app_path)
  sparkle_framework_path = File.join(app_path, "Contents", "Frameworks", "Sparkle.framework")
  return unless File.directory?(sparkle_framework_path)

  UI.message("Re-signing Sparkle.framework nested helpers for notarization")

  sparkle_version_path = File.join(sparkle_framework_path, "Versions", "B")
  sparkle_signing_targets = [
    { path: File.join(sparkle_version_path, "XPCServices", "Installer.xpc") },
    {
      path: File.join(sparkle_version_path, "XPCServices", "Downloader.xpc"),
      preserve_metadata: "entitlements"
    },
    { path: File.join(sparkle_version_path, "Autoupdate") },
    { path: File.join(sparkle_version_path, "Updater.app") },
    { path: sparkle_framework_path }
  ]

  sparkle_signing_targets.each do |target|
    path = target.fetch(:path)
    next unless File.exist?(path)

    codesign_for_distribution!(path, preserve_metadata: target[:preserve_metadata])
  end

  codesign_for_distribution!(app_path, preserve_metadata: "identifier,entitlements")
end

def generate_sparkle_appcast!(archives_dir, metadata)
  tool_path = sparkle_tool_path("generate_appcast")

  Tempfile.create(["sparkle-private-ed-key", ".txt"]) do |private_key_file|
    private_key_file.write(sparkle_private_ed_key(metadata))
    private_key_file.flush

    sh(
      [
        shell_escape(tool_path),
        "--ed-key-file", shell_escape(private_key_file.path),
        "--download-url-prefix", shell_escape(github_release_download_base_url(metadata)),
        "--release-notes-url-prefix", shell_escape(github_release_download_base_url(metadata)),
        "--full-release-notes-url", shell_escape(github_release_page_url(metadata)),
        "--link", shell_escape(github_release_page_url(metadata)),
        "--versions", shell_escape(metadata[:build_number]),
        "--maximum-versions", "1",
        "-o", shell_escape("appcast.xml"),
        shell_escape(archives_dir)
      ].join(" ")
    )
  end
end

def setup_signing_keychain
  keychain_password = ENV.fetch("MACOS_KEYCHAIN_PASSWORD")
  keychain_path = signing_keychain_path

  if File.exist?(keychain_path)
    UI.user_error!("Refusing to delete keychain directory #{keychain_path}") if File.directory?(keychain_path)
    sh("security delete-keychain #{shell_escape(keychain_path)}")
  end

  create_keychain(
    path: keychain_path,
    password: keychain_password,
    default_keychain: true,
    unlock: true,
    timeout: 21600,
    lock_when_sleeps: true,
    lock_after_timeout: true,
    add_to_search_list: true
  )

  {
    name: signing_keychain_name,
    path: keychain_path,
    password: keychain_password
  }
end

def with_app_store_connect_api_key_path(required: true)
  raw_json = ENV["APP_STORE_CONNECT_API_KEY_JSON"].to_s
  if raw_json.empty?
    UI.user_error!("APP_STORE_CONNECT_API_KEY_JSON is required") if required
    return yield(nil)
  end

  json = JSON.parse(raw_json)

  Tempfile.create(["app_store_connect_api_key", ".json"]) do |file|
    file.write(JSON.pretty_generate(json))
    file.flush
    yield(file.path)
  end
end

def with_sigh_certificate_verification_skipped
  previous = ENV["SIGH_SKIP_CERTIFICATE_VERIFICATION"]
  ENV["SIGH_SKIP_CERTIFICATE_VERIFICATION"] = "true"
  yield
ensure
  previous.nil? ? ENV.delete("SIGH_SKIP_CERTIFICATE_VERIFICATION") : ENV["SIGH_SKIP_CERTIFICATE_VERIFICATION"] = previous
end

def find_codesigning_identities(keychain_path)
  stdout, _stderr, _status = Open3.capture3("security", "find-identity", "-v", "-p", "codesigning", keychain_path)
  stdout
end

def ensure_developer_id_identity!(keychain_path)
  identities = find_codesigning_identities(keychain_path)
  return if identities.include?(DEVELOPER_ID_APPLICATION_IDENTITY)

  UI.user_error!("Developer ID Application identity is not available in #{keychain_path}")
end

def import_match_signing_assets!(output_dir, keychain)
  cert_path = Dir[File.join(output_dir, "*.cer")].max
  p12_path = Dir[File.join(output_dir, "*.p12")].max

  UI.user_error!("match did not export a certificate into #{output_dir}") unless cert_path
  UI.user_error!("match did not export a private key into #{output_dir}") unless p12_path

  import_certificate(
    certificate_path: cert_path,
    keychain_path: keychain[:path],
    keychain_password: keychain[:password],
    log_output: false
  )

  import_certificate(
    certificate_path: p12_path,
    certificate_password: match_certificate_password,
    certificate_format: "pkcs12",
    keychain_path: keychain[:path],
    keychain_password: keychain[:password],
    log_output: false
  )

  ensure_developer_id_identity!(keychain[:path])
end

def collect_sparkle_assets!(metadata)
  UI.user_error!("Missing ZIP archive at #{metadata[:zip_path]}") unless File.exist?(metadata[:zip_path])

  FileUtils.rm_rf(metadata[:sparkle_dir])
  FileUtils.mkdir_p(metadata[:sparkle_dir])

  Dir.mktmpdir("sparkle-archives") do |archives_dir|
    current_zip_path = File.join(archives_dir, File.basename(metadata[:zip_path]))
    release_notes_path = File.join(archives_dir, "#{File.basename(metadata[:zip_path], ".zip")}.md")

    FileUtils.cp(metadata[:zip_path], current_zip_path)
    download_previous_release_archives!(archives_dir, metadata)
    write_sparkle_release_notes!(release_notes_path, metadata)
    generate_sparkle_appcast!(archives_dir, metadata)

    FileUtils.cp(File.join(archives_dir, "appcast.xml"), metadata[:appcast_path])
    FileUtils.cp(release_notes_path, metadata[:sparkle_release_notes_path])

    Dir[File.join(archives_dir, "*.delta")].sort.each do |delta_path|
      FileUtils.cp(delta_path, File.join(metadata[:sparkle_dir], File.basename(delta_path)))
    end
  end

  [metadata[:appcast_path], metadata[:sparkle_release_notes_path], *Dir[File.join(metadata[:sparkle_dir], "*.delta")].sort]
end

def ensure_bundle_id_exists!(metadata, api_key_path)
  Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.from(filepath: api_key_path)

  if Spaceship::ConnectAPI::BundleId.find(metadata[:bundle_id])
    UI.message("Bundle ID #{metadata[:bundle_id]} already exists")
    return
  end

  UI.important("Creating macOS Bundle ID #{metadata[:bundle_id]}")
  Spaceship::ConnectAPI::BundleId.create(
    name: metadata[:bundle_id_name],
    platform: Spaceship::ConnectAPI::BundleIdPlatform::MAC_OS,
    identifier: metadata[:bundle_id]
  )
end

def macos_flavor_overrides_xcconfig_path
  File.join(workspace_root, "macos", "Runner", "Configs", "FlavorOverrides.xcconfig")
end

def macos_runner_project_path
  File.join(workspace_root, "macos", "Runner.xcodeproj")
end

def macos_runner_pbxproj_path
  File.join(macos_runner_project_path, "project.pbxproj")
end

def with_macos_runner_project_restored
  path = macos_runner_pbxproj_path
  original = File.binread(path)
  yield
ensure
  File.binwrite(path, original) if original
end

def write_macos_flavor_overrides!(metadata)
  path = macos_flavor_overrides_xcconfig_path
  FileUtils.mkdir_p(File.dirname(path))
  File.write(path, <<~XCCONFIG)
    // Generated by fastlane; do not commit.
    PRODUCT_NAME = #{metadata[:app_name]}
    PRODUCT_BUNDLE_IDENTIFIER = #{metadata[:bundle_id]}
    MACOS_APP_ICON_FILE = #{metadata[:app_icon_file]}
  XCCONFIG
end

def delete_macos_flavor_overrides!
  FileUtils.rm_f(macos_flavor_overrides_xcconfig_path)
end

def plist_value(path, key)
  stdout, stderr, status = Open3.capture3("/usr/libexec/PlistBuddy", "-c", "Print :#{key}", path)
  UI.user_error!("Failed to read #{key} from #{path}: #{stderr}") unless status.success?
  stdout.strip
end

def verify_built_app_metadata!(metadata)
  info_plist = File.join(metadata[:app_path], "Contents", "Info.plist")
  UI.user_error!("Missing Info.plist at #{info_plist}") unless File.exist?(info_plist)

  actual_bundle_id = plist_value(info_plist, "CFBundleIdentifier")
  actual_bundle_name = plist_value(info_plist, "CFBundleName")
  actual_icon_file = plist_value(info_plist, "CFBundleIconFile")

  UI.user_error!("Expected bundle id #{metadata[:bundle_id]}, got #{actual_bundle_id}") unless actual_bundle_id == metadata[:bundle_id]
  UI.user_error!("Expected bundle name #{metadata[:app_name]}, got #{actual_bundle_name}") unless actual_bundle_name == metadata[:app_name]
  UI.user_error!("Expected icon file #{metadata[:app_icon_file]}, got #{actual_icon_file}") unless actual_icon_file == metadata[:app_icon_file]
end

platform :mac do
  private_lane :validate_signing_environment do |options|
    readonly = options.fetch(:readonly, match_readonly?)

    ENV.fetch("MATCH_GIT_URL")
    ENV.fetch("MATCH_PASSWORD")
    ENV.fetch("MATCH_CERTIFICATE_PASSWORD")
    ENV.fetch("MACOS_KEYCHAIN_PASSWORD")

    return if readonly

    UI.user_error!("APP_STORE_CONNECT_API_KEY_JSON is required when MATCH_READONLY is false") if ENV["APP_STORE_CONNECT_API_KEY_JSON"].to_s.strip.empty?
  end

  private_lane :prepare_signing do |options|
    metadata = release_metadata(flavor: single_macos_release_flavor(options))
    keychain = setup_signing_keychain
    readonly = options.fetch(:readonly, match_readonly?)
    validate_signing_environment(readonly: readonly)

    Dir.mktmpdir("match-signing-assets") do |output_dir|
      with_app_store_connect_api_key_path(required: !readonly) do |api_key_path|
        ensure_bundle_id_exists!(metadata, api_key_path) unless readonly

        match_options = {
          type: "developer_id",
          app_identifier: metadata[:bundle_id],
          platform: "macos",
          readonly: readonly,
          git_branch: match_git_branch,
          team_id: "SZTB68DXM4",
          keychain_name: keychain[:name],
          keychain_password: keychain[:password],
          output_path: output_dir
        }
        match_options[:api_key_path] = api_key_path if api_key_path
        with_sigh_certificate_verification_skipped do
          match(match_options)
        end
      end

      import_match_signing_assets!(output_dir, keychain)
    end

    profile_name = lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING].fetch(metadata[:bundle_id])
    update_code_signing_settings(
      use_automatic_signing: false,
      path: macos_runner_project_path,
      targets: ["Runner"],
      build_configurations: ["Release"],
      sdk: "macosx*",
      team_id: "SZTB68DXM4",
      bundle_identifier: metadata[:bundle_id],
      code_sign_identity: "Developer ID Application",
      entitlements_file_path: "Runner/Release.entitlements",
      profile_name: profile_name
    )
  end

  private_lane :notarize_app_bundle do |options|
    metadata = release_metadata(flavor: single_macos_release_flavor(options))
    UI.user_error!("Missing app bundle at #{metadata[:app_path]}") unless File.directory?(metadata[:app_path])

    resign_sparkle_for_notarization!(metadata)

    with_app_store_connect_api_key_path do |api_key_path|
      notarize(
        package: metadata[:app_path],
        bundle_id: metadata[:bundle_id],
        api_key_path: api_key_path,
        use_notarytool: true,
        print_log: true
      )
    end

    sh("xcrun stapler staple #{shell_escape(metadata[:app_path])}")
  end

  private_lane :notarize_dmg do |options|
    metadata = release_metadata(flavor: single_macos_release_flavor(options))
    UI.user_error!("Missing disk image at #{metadata[:dmg_path]}") unless File.exist?(metadata[:dmg_path])

    with_app_store_connect_api_key_path do |api_key_path|
      notarize(
        package: metadata[:dmg_path],
        bundle_id: metadata[:bundle_id],
        api_key_path: api_key_path,
        use_notarytool: true,
        print_log: true
      )
    end

    sh("xcrun stapler staple #{shell_escape(metadata[:dmg_path])}")
  end

  private_lane :upload_github_release do |options|
    flavors = options[:flavors] || macos_release_flavors
    metadata_items = flavors.map { |flavor| release_metadata(flavor: flavor) }
    metadata = metadata_items.first
    extra_assets = Array((lane_context[:SPARKLE_RELEASE_ASSETS] || [])).compact
    assets = metadata_items.flat_map { |item| [item[:zip_path], item[:dmg_path]] } + extra_assets

    set_github_release(
      repository_name: ENV.fetch("RELEASE_REPOSITORY"),
      api_bearer: ENV.fetch("GITHUB_TOKEN"),
      tag_name: metadata[:tag],
      name: metadata[:release_name],
      commitish: ENV.fetch("RELEASE_COMMITISH"),
      is_draft: false,
      is_prerelease: metadata.fetch(:is_prerelease),
      is_generate_release_notes: true,
      upload_assets: assets
    )
  end

  desc "Build the macOS release app bundle"
  lane :build do |options|
    metadata = release_metadata(flavor: single_macos_release_flavor(options))
    plist_path = File.join(workspace_root, "macos", "Runner", "Info.plist")

    FileUtils.mkdir_p(metadata[:dist_dir])
    write_macos_flavor_overrides!(metadata)

    begin
      sh("cd #{shell_escape(workspace_root)} && fvm flutter pub get")
      with_restored_file(plist_path) do |restored_plist_path|
        configure_sparkle_info_plist!(restored_plist_path, metadata) if sparkle_enabled_for_release?(metadata)

        Bundler.with_unbundled_env do
          dart_defines = [
            "ZCASH_DEFAULT_NETWORK=#{metadata[:zcash_default_network]}",
            "VIZOR_RELEASE_VERSION=#{metadata[:asset_version]}"
          ]
          sh(
            [
              "cd #{shell_escape(workspace_root)} &&",
              "fvm flutter build macos --release --no-pub",
              *dart_defines.map { |dart_define| "--dart-define=#{shell_escape(dart_define)}" },
              "--build-name", shell_escape(metadata[:version]),
              "--build-number", shell_escape(metadata[:build_number])
            ].join(" ")
          )
        end
      end

      UI.user_error!("Expected app bundle at #{metadata[:app_path]}") unless File.directory?(metadata[:app_path])
      verify_built_app_metadata!(metadata)
    ensure
      delete_macos_flavor_overrides!
    end
  end

  desc "Package the macOS release build into ZIP and DMG"
  lane :package do |options|
    build(flavor: single_macos_release_flavor(options)) unless options[:skip_build]

    metadata = release_metadata(flavor: single_macos_release_flavor(options))
    FileUtils.mkdir_p(metadata[:dist_dir])
    FileUtils.rm_f([metadata[:zip_path], metadata[:dmg_path]])

    UI.user_error!("Expected app bundle at #{metadata[:app_path]}") unless File.directory?(metadata[:app_path])

    sh("ditto -c -k --sequesterRsrc --keepParent #{shell_escape(metadata[:app_path])} #{shell_escape(metadata[:zip_path])}")

    dmg_script_path = File.join(workspace_root, "scripts", "package-macos-release-dmg.sh")
    UI.user_error!("Missing DMG packaging script at #{dmg_script_path}") unless File.executable?(dmg_script_path)

    sh([
      shell_escape(dmg_script_path),
      "--app-path", shell_escape(metadata[:app_path]),
      "--output", shell_escape(metadata[:dmg_path]),
      "--app-name", shell_escape(metadata[:app_name]),
      "--volume-name", shell_escape(metadata[:volume_name])
    ].join(" "))
  end

  desc "Install macOS signing identities and provisioning profiles via match"
  lane :sync_signing do |options|
    with_macos_runner_project_restored do
      prepare_signing(readonly: options.fetch(:readonly, match_readonly?), flavor: single_macos_release_flavor(options))
    end
  end

  desc "Build, notarize, package, and upload the macOS release"
  lane :release do
    flavors = macos_release_flavors
    metadata_items = flavors.map { |flavor| release_metadata(flavor: flavor) }

    metadata_items.each { |metadata| validate_sparkle_environment!(metadata) }
    lane_context[:SPARKLE_RELEASE_ASSETS] = []

    metadata_items.each do |metadata|
      with_macos_runner_project_restored do
        prepare_signing(readonly: match_readonly?, flavor: metadata[:flavor])
        build(flavor: metadata[:flavor])
        notarize_app_bundle(flavor: metadata[:flavor])
        package(skip_build: true, flavor: metadata[:flavor])
        notarize_dmg(flavor: metadata[:flavor])
      end

      lane_context[:SPARKLE_RELEASE_ASSETS] += collect_sparkle_assets!(metadata) if sparkle_enabled_for_release?(metadata)
    end

    upload_github_release(flavors: flavors)
  end
end
